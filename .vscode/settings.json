{
    "liveServer.settings.ignoreFiles": [
      "**/.git/**",
      "**/.vscode/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/*.log"
    ],
    "liveServer.settings.fileTypes": [
      "html",
